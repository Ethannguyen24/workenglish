{w:"Tuần 11",t:"Thuyết trình & Đàm phán",d:"Present, thuyết phục client, xử lý câu hỏi khó, chốt deal."},
{w:"Tuần 12",t:"Tổng ôn & mô phỏng",d:"Không học từ mới. Ôn các từ khó + mô phỏng tình huống thật: họp, present, đàm phán."},
];

/* ===== CONFIG: dán URL Apps Script (.../exec) và đặt tên người dùng ===== */
const CFG = {
  API_URL: localStorage.getItem('we_api') || '',   // điền qua màn hình Cài đặt
  USER:    localStorage.getItem('we_user') || 'ethan'
};

/* ===== State: local trước, đồng bộ Sheet nền ===== */
let DB = loadDB();
function loadDB(){
  try{ const raw=localStorage.getItem('we_db'); if(raw) return JSON.parse(raw); }catch(e){}
  return { cards:{}, streak:0, lastDay:null };
}
function saveDB(){
  try{ localStorage.setItem('we_db', JSON.stringify(DB)); }catch(e){}
  renderStats();
}

/* ===== JSONP helper (tránh lỗi CORS với Apps Script) ===== */
function jsonp(url){
  return new Promise((resolve,reject)=>{
    const cb='we_cb_'+Math.random().toString(36).slice(2);
    const s=document.createElement('script');
    const to=setTimeout(()=>{cleanup();reject(new Error('timeout'));},12000);
    function cleanup(){clearTimeout(to);delete window[cb];s.remove();}
    window[cb]=(data)=>{cleanup();resolve(data);};
    s.onerror=()=>{cleanup();reject(new Error('network'));};
    s.src=url+(url.includes('?')?'&':'?')+'callback='+cb;
    document.body.appendChild(s);
  });
}

/* Tải tiến độ từ Sheet (gộp vào DB) */
async function pullFromSheet(){
  if(!CFG.API_URL) return;
  try{
    setSync('Đang tải tiến độ...');
    const r=await jsonp(CFG.API_URL+'?user='+encodeURIComponent(CFG.USER));
    if(r&&r.ok){
      DB.cards=r.cards||{}; DB.streak=r.streak||0; DB.lastDay=r.lastDay??null;
      saveDB(); buildLearnQueue(); renderLearn(); renderPlan();
      setSync('✓ Đã đồng bộ từ Google Sheet');
    }
  }catch(e){ setSync('⚠️ Không tải được Sheet (kiểm tra URL/quyền)'); }
}

/* Lưu 1 thẻ lên Sheet */
async function pushCard(i){
  if(!CFG.API_URL) return;
  const c=cardOf(i), v=VOCAB[i];
  const q='?action=save&user='+encodeURIComponent(CFG.USER)
    +'&wordIndex='+i+'&term='+encodeURIComponent(v.t)
    +'&box='+c.box+'&dueDay='+c.due+'&reps='+c.reps
    +'&streak='+DB.streak+'&lastDay='+(DB.lastDay??'');
  try{ setSync('Đang lưu...'); await jsonp(CFG.API_URL+q); setSync('✓ Đã lưu vào Sheet'); }
  catch(e){ setSync('⚠️ Lưu thất bại — sẽ thử lại sau'); }
}

function setSync(msg){ const el=document.getElementById('sync'); if(el) el.textContent=msg; }

function cardOf(i){
  if(!DB.cards[i]) DB.cards[i] = {seen:false, box:0, due:0, reps:0};
  return DB.cards[i];
}
const today = ()=> Math.floor(Date.now()/86400000);
const INTERVALS = [0,1,2,4,7,15,30]; // box -> days

function dueList(){
  const t = today();
  return VOCAB.map((v,i)=>({v,i})).filter(({i})=>{ const c=cardOf(i); return c.seen && c.due<=t; });
}
function newList(){
  return VOCAB.map((v,i)=>({v,i})).filter(({i})=>!cardOf(i).seen);
}

/* ===== Stats ===== */
function renderStats(){
  const learned = VOCAB.filter((_,i)=>cardOf(i).seen).length;
  document.getElementById('s-learned').textContent = learned;
  document.getElementById('s-due').textContent = dueList().length;
  document.getElementById('s-streak').textContent = DB.streak;
  document.getElementById('s-total').textContent = VOCAB.length;
}

/* ===== Tabs ===== */
document.querySelectorAll('.tab').forEach(tab=>{
  tab.onclick=()=>{
    document.querySelectorAll('.tab').forEach(t=>t.classList.remove('active'));
    tab.classList.add('active');
    ['learn','speak','plan','settings'].forEach(v=>{
      document.getElementById('view-'+v).classList.toggle('hidden', v!==tab.dataset.view);
    });
    if(tab.dataset.view==='speak') renderSpeak();
    if(tab.dataset.view==='settings') renderSettings();
  };
});

/* ===== LEARN view ===== */
let learnQueue=[], learnIdx=0, revealed=false;
function buildLearnQueue(){
  const due = dueList();
  const news = newList().slice(0, Math.max(0, 15 - 0)); // up to 15 new
  learnQueue = [...due, ...news];
  learnIdx=0;
}
function renderLearn(){
  const el = document.getElementById('view-learn');
  if(!learnQueue.length || learnIdx>=learnQueue.length){
    const t=today();
    if(DB.lastDay!==t && learnIdx>0){ DB.streak = (DB.lastDay===t-1||DB.lastDay===null)?DB.streak+1:1; DB.lastDay=t; saveDB(); }
    el.innerHTML = `<div class="card"><div class="empty"><div class="big">🎉</div>
      <h3 style="font-family:Fraunces,serif;margin:10px 0">Xong buổi học hôm nay!</h3>
      <p style="margin-top:8px">Bạn đã ôn & học hết phần đến hạn. Qua tab 🎙️ <b>Luyện nói</b> để dùng từ vừa học nhé.</p>
      <button class="btn btn-moss btn-full" style="margin-top:18px" onclick="document.querySelector('[data-view=speak]').click()">🎙️ Luyện nói ngay</button>
      </div></div>`;
    return;
  }
  const {v,i} = learnQueue[learnIdx];
  const c = cardOf(i);
  const isReview = c.seen;
  el.innerHTML = `
   <div class="card">
     <div style="display:flex;justify-content:space-between;align-items:center">
       <span class="topic-pill">${v.topic}</span>
       <span style="font-size:12px;color:#8a7a64">${learnIdx+1}/${learnQueue.length} ${isReview?'· ôn':'· mới'}</span>
     </div>
     <div class="word">${v.t}</div>
     <div class="phon">${v.p} · <span class="pos">${v.pos}</span></div>
     <button class="btn btn-ghost btn-sm" style="margin-top:12px" onclick="speakWord('${v.t.replace(/'/g,"\\'")}')">🔊 Nghe phát âm</button>
     <div id="reveal" class="${revealed?'':'hidden'}">
       <div class="meaning">${v.vi}</div>
       <div class="example">"${v.ex}"<span class="vi">${v.exvi}</span></div>
     </div>
     ${revealed?`
       <div class="srs-row">
         <button class="srs srs-hard" onclick="grade(${i},'hard')">Khó<small>ôn lại sớm</small></button>
         <button class="srs srs-ok" onclick="grade(${i},'ok')">Được<small>+vài ngày</small></button>
         <button class="srs srs-easy" onclick="grade(${i},'easy')">Dễ<small>nhớ rồi</small></button>
       </div>`:`
       <button class="btn btn-primary btn-full" style="margin-top:22px" onclick="reveal()">Hiện nghĩa & ví dụ</button>`}
   </div>`;
}
function reveal(){ revealed=true; renderLearn(); }
function grade(i,level){
  const c=cardOf(i); c.seen=true; c.reps++;
  if(level==='hard') c.box=Math.max(1,c.box);
  else if(level==='ok') c.box=Math.min(INTERVALS.length-1,c.box+1);
  else c.box=Math.min(INTERVALS.length-1,c.box+2);
  c.due = today()+INTERVALS[c.box];
  saveDB();
  revealed=false; learnIdx++;
  const t=today();
  if(DB.lastDay!==t){ DB.streak=(DB.lastDay===t-1||DB.lastDay===null)?DB.streak+1:1; DB.lastDay=t; }
  pushCard(i);
  renderLearn();
}

/* ===== Pronunciation (TTS) ===== */
function speakWord(text){
  if(!('speechSynthesis' in window)) return;
  const u=new SpeechSynthesisUtterance(text);
  u.lang='en-US'; u.rate=.9;
  speechSynthesis.cancel(); speechSynthesis.speak(u);
}

/* ===== SPEAK view ===== */
let speakPool=[], speakIdx=0;
function renderSpeak(){
  const el=document.getElementById('view-speak');
  const learned = VOCAB.map((v,i)=>({v,i})).filter(({i})=>cardOf(i).seen);
  if(learned.length<1){
    el.innerHTML=`<div class="card"><div class="empty"><div class="big">🎙️</div>
      <p style="margin-top:10px">Hãy học vài từ ở tab 📖 <b>Học từ</b> trước, rồi quay lại đây luyện nói các câu chứa từ đó.</p></div></div>`;
    return;
  }
  speakPool = learned;
  if(speakIdx>=speakPool.length) speakIdx=0;
  const {v}=speakPool[speakIdx];
  const supported = ('webkitSpeechRecognition' in window)||('SpeechRecognition' in window);
  el.innerHTML=`
   <div class="card">
     <span class="topic-pill">${v.topic}</span>
     <p style="font-size:13px;color:#8a7a64;margin-bottom:6px">Đọc to câu sau (chứa <b>${v.t}</b>):</p>
     <div class="speak-target" id="tgt">"${v.ex.replace(new RegExp('('+v.t+')','i'),'<b>$1</b>')}"</div>
     <button class="btn btn-ghost btn-sm" onclick="speakWord('${v.ex.replace(/'/g,"\\'")}')">🔊 Nghe mẫu</button>
     ${supported?`
       <button class="mic-btn" id="mic" onclick="toggleRec('${v.ex.replace(/'/g,"\\'")}')">🎤</button>
       <p style="text-align:center;font-size:12px;color:#8a7a64" id="mic-hint">Nhấn mic và đọc câu trên</p>
       <div class="heard hidden" id="heard"></div>
     `:`<p class="note" style="margin-top:18px">⚠️ Trình duyệt này không hỗ trợ nhận diện giọng nói. Hãy mở bằng <b>Chrome</b> hoặc <b>Safari</b>. Bạn vẫn có thể nghe mẫu và đọc theo.</p>`}
     <div class="btn-row" style="margin-top:20px">
       <button class="btn btn-ghost" onclick="prevSpeak()">← Trước</button>
       <button class="btn btn-primary" onclick="nextSpeak()">Câu khác →</button>
     </div>
   </div>`;
}
function nextSpeak(){ speakIdx=(speakIdx+1)%speakPool.length; renderSpeak(); }
function prevSpeak(){ speakIdx=(speakIdx-1+speakPool.length)%speakPool.length; renderSpeak(); }

let rec=null, recOn=false;
function toggleRec(target){
  const SR = window.SpeechRecognition||window.webkitSpeechRecognition;
  if(!SR) return;
  if(recOn){ rec&&rec.stop(); return; }
  rec=new SR(); rec.lang='en-US'; rec.interimResults=false; rec.maxAlternatives=1;
  const mic=document.getElementById('mic'), hint=document.getElementById('mic-hint');
  rec.onstart=()=>{recOn=true; mic.classList.add('rec'); mic.textContent='⏹'; hint.textContent='Đang nghe... đọc to câu trên';};
  rec.onerror=(e)=>{ hint.textContent='Lỗi micro: '+e.error+'. Kiểm tra quyền micro.'; };
  rec.onend=()=>{recOn=false; mic.classList.remove('rec'); mic.textContent='🎤';};
  rec.onresult=(e)=>{
    const said=e.results[0][0].transcript;
    showScore(target, said);
  };
  rec.start();
}
function norm(s){return s.toLowerCase().replace(/[^a-z0-9\s']/g,'').replace(/\s+/g,' ').trim();}
function showScore(target, said){
  const tw=norm(target).split(' '), sw=norm(said).split(' ');
  const swSet=[...sw];
  let hit=0; const marks=tw.map(w=>{
    const idx=swSet.indexOf(w);
    if(idx>=0){swSet.splice(idx,1); hit++; return `<span class="w-ok">${w}</span>`;}
    return `<span class="w-miss">${w}</span>`;
  });
  const pct=Math.round(hit/tw.length*100);
  const cls = pct>=80?'match-good':pct>=50?'match-mid':'match-low';
  const msg = pct>=80?'Tuyệt vời! Phát âm rõ ràng 👏':pct>=50?'Khá ổn, thử lại để rõ hơn 💪':'Đọc chậm và rõ từng từ nhé 🙂';
  const h=document.getElementById('heard');
  h.classList.remove('hidden');
  h.innerHTML=`<span class="lbl">Máy nghe được:</span>${said}
    <div class="score ${cls}">${pct}%</div>
    <p style="text-align:center;font-size:13px;color:#6a5c48">${msg}</p>
    <div class="diff" style="margin-top:10px;font-size:15px;line-height:1.8">${marks.join(' ')}</div>`;
}

/* ===== PLAN view ===== */
function renderPlan(){
  const el=document.getElementById('view-plan');
  const learned=VOCAB.filter((_,i)=>cardOf(i).seen).length;
  const pct=Math.round(learned/VOCAB.length*100);
  el.innerHTML=`
    <div class="card" style="margin-bottom:16px">
      <h3 style="font-family:Fraunces,serif;font-size:20px">Lộ trình 12 tuần · công việc</h3>
      <p style="font-size:14px;color:#6a5c48;margin-top:6px">20–25 phút mỗi tối · 6 ngày/tuần. Mỗi tối: ôn (5p) → học mới (7p) → luyện nói (8p) → nhập từ (5p).</p>
      <div class="progressbar"><i style="width:${pct}%"></i></div>
      <p style="font-size:12px;color:#8a7a64;margin-top:6px">${learned}/${VOCAB.length} từ · ${pct}% lộ trình mẫu</p>
    </div>
    ${PLAN.map(p=>`<div class="week"><h4>${p.t}<span>${p.w}</span></h4><p>${p.d}</p></div>`).join('')}
  `;
}

/* ===== SETTINGS view ===== */
function renderSettings(){
  const el=document.getElementById('view-settings');
  el.innerHTML=`
   <div class="card">
     <h3 style="font-family:Fraunces,serif;font-size:20px">Đồng bộ Google Sheet</h3>
     <p style="font-size:14px;color:#6a5c48;margin-top:6px;line-height:1.5">
       Dán URL Apps Script (kết thúc bằng <b>/exec</b>) để lưu tiến độ học vào Google Sheet của bạn.</p>
     <label style="display:block;font-size:12px;color:#8a7a64;margin-top:16px;text-transform:uppercase;letter-spacing:.5px">Apps Script URL</label>
     <input id="in-url" placeholder="https://script.google.com/macros/s/.../exec"
       value="${CFG.API_URL}" style="width:100%;padding:12px;border:1px solid var(--line);border-radius:10px;font-size:14px;margin-top:6px;font-family:Outfit;background:var(--paper)">
     <label style="display:block;font-size:12px;color:#8a7a64;margin-top:14px;text-transform:uppercase;letter-spacing:.5px">Tên người dùng (để tách dữ liệu)</label>
     <input id="in-user" value="${CFG.USER}" style="width:100%;padding:12px;border:1px solid var(--line);border-radius:10px;font-size:14px;margin-top:6px;font-family:Outfit;background:var(--paper)">
     <div class="btn-row" style="margin-top:18px">
       <button class="btn btn-primary" onclick="saveCfg()">💾 Lưu & Đồng bộ</button>
       <button class="btn btn-ghost" onclick="pullFromSheet()">⬇️ Tải lại từ Sheet</button>
     </div>
     <p class="note" style="margin-top:16px">Tiến độ luôn lưu sẵn trên trình duyệt này. Google Sheet giúp đồng bộ giữa nhiều thiết bị.</p>
   </div>`;
}
function saveCfg(){
  CFG.API_URL=document.getElementById('in-url').value.trim();
  CFG.USER=document.getElementById('in-user').value.trim()||'ethan';
  localStorage.setItem('we_api',CFG.API_URL);
  localStorage.setItem('we_user',CFG.USER);
  pullFromSheet();
}

/* ===== Init ===== */
buildLearnQueue();
renderLearn();
renderPlan();
renderStats();
if(CFG.API_URL) pullFromSheet();

</script>
