<!DOCTYPE html>
<html lang="vi">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>WorkEnglish — Học tiếng Anh công việc & Luyện nói</title>
<style>
@import url('https://fonts.googleapis.com/css2?family=Fraunces:opsz,wght@9..144,400;9..144,600;9..144,900&family=Outfit:wght@300;400;500;600;700&display=swap');

:root{
  --ink:#1a1410;
  --paper:#f4ede2;
  --card:#fffdf8;
  --rust:#c2552b;
  --rust-deep:#9c3d1c;
  --moss:#4a5d3a;
  --gold:#d49a3a;
  --line:#d8cab4;
  --shadow:rgba(60,40,20,.16);
}
*{margin:0;padding:0;box-sizing:border-box}
body{
  font-family:'Outfit',sans-serif;
  background:var(--paper);
  color:var(--ink);
  background-image:radial-gradient(circle at 12% 18%,rgba(194,85,43,.06),transparent 40%),radial-gradient(circle at 88% 82%,rgba(74,93,58,.06),transparent 42%);
  min-height:100vh;
}
.wrap{max-width:760px;margin:0 auto;padding:24px 18px 80px}

/* Header */
header{text-align:center;padding:18px 0 8px}
.logo{font-family:'Fraunces',serif;font-weight:900;font-size:30px;letter-spacing:-.5px;color:var(--rust-deep)}
.logo span{color:var(--moss)}
.tag{font-size:13px;color:#7a6c58;margin-top:2px;font-weight:300}

/* Progress strip */
.stats{display:flex;gap:10px;margin:18px 0;flex-wrap:wrap}
.stat{flex:1;min-width:90px;background:var(--card);border:1px solid var(--line);border-radius:14px;padding:12px 14px;box-shadow:0 2px 0 var(--shadow)}
.stat .n{font-family:'Fraunces',serif;font-weight:900;font-size:24px;line-height:1}
.stat .l{font-size:11px;color:#8a7a64;margin-top:4px;text-transform:uppercase;letter-spacing:.5px}

/* Tabs */
.tabs{display:flex;gap:6px;background:var(--card);border:1px solid var(--line);border-radius:14px;padding:5px;margin-bottom:20px}
.tab{flex:1;border:none;background:none;font-family:'Outfit';font-weight:600;font-size:13px;padding:10px 6px;border-radius:10px;cursor:pointer;color:#8a7a64;transition:.2s}
.tab.active{background:var(--rust);color:#fff;box-shadow:0 2px 6px rgba(194,85,43,.35)}

/* Card */
.card{background:var(--card);border:1px solid var(--line);border-radius:20px;padding:26px 22px;box-shadow:0 6px 0 var(--shadow);position:relative}
.topic-pill{display:inline-block;font-size:11px;font-weight:600;color:var(--moss);background:rgba(74,93,58,.1);padding:4px 12px;border-radius:20px;text-transform:uppercase;letter-spacing:.6px;margin-bottom:16px}

.word{font-family:'Fraunces',serif;font-weight:900;font-size:38px;letter-spacing:-1px;line-height:1.05}
.phon{color:#a08b6e;font-size:15px;margin-top:4px;font-style:italic}
.pos{display:inline-block;font-size:12px;color:var(--rust-deep);font-weight:600;margin-top:8px}
.meaning{font-size:18px;margin-top:14px;font-weight:500}
.example{margin-top:16px;padding:14px 16px;background:var(--paper);border-left:3px solid var(--gold);border-radius:8px;font-size:15px;line-height:1.5}
.example .vi{display:block;color:#8a7a64;font-size:13px;margin-top:6px;font-style:italic}

.hidden{display:none!important}

/* Buttons */
.btn-row{display:flex;gap:10px;margin-top:22px;flex-wrap:wrap}
.btn{flex:1;min-width:120px;border:none;font-family:'Outfit';font-weight:600;font-size:15px;padding:14px;border-radius:12px;cursor:pointer;transition:.15s;display:flex;align-items:center;justify-content:center;gap:8px}
.btn:active{transform:translateY(2px)}
.btn-primary{background:var(--rust);color:#fff;box-shadow:0 3px 0 var(--rust-deep)}
.btn-ghost{background:var(--card);color:var(--ink);border:1px solid var(--line);box-shadow:0 3px 0 var(--shadow)}
.btn-moss{background:var(--moss);color:#fff;box-shadow:0 3px 0 #34452a}
.btn-sm{flex:0 0 auto;min-width:auto;padding:12px 16px;font-size:14px}
.btn-full{width:100%;flex:none}

.srs-row{display:flex;gap:8px;margin-top:18px}
.srs{flex:1;border:none;font-family:'Outfit';font-weight:600;font-size:13px;padding:12px 4px;border-radius:10px;cursor:pointer;color:#fff;transition:.15s}
.srs:active{transform:translateY(2px)}
.srs-hard{background:#b5483a}
.srs-ok{background:var(--gold)}
.srs-easy{background:var(--moss)}
.srs small{display:block;font-size:10px;opacity:.85;font-weight:400;margin-top:2px}

/* Speaking */
.speak-target{font-size:20px;font-weight:500;line-height:1.5;margin:8px 0 4px}
.speak-target b{color:var(--rust-deep)}
.mic-btn{width:84px;height:84px;border-radius:50%;border:none;background:var(--rust);color:#fff;font-size:32px;cursor:pointer;margin:18px auto;display:flex;align-items:center;justify-content:center;box-shadow:0 4px 0 var(--rust-deep);transition:.15s}
.mic-btn.rec{background:#b5483a;animation:pulse 1.1s infinite}
@keyframes pulse{0%{box-shadow:0 0 0 0 rgba(181,72,58,.5)}70%{box-shadow:0 0 0 18px rgba(181,72,58,0)}100%{box-shadow:0 0 0 0 rgba(181,72,58,0)}}
.heard{margin-top:14px;padding:14px;border-radius:12px;background:var(--paper);font-size:15px;min-height:50px}
.heard .lbl{font-size:11px;color:#8a7a64;text-transform:uppercase;letter-spacing:.5px;display:block;margin-bottom:6px}
.score{font-family:'Fraunces',serif;font-weight:900;font-size:40px;text-align:center;margin-top:10px}
.match-good{color:var(--moss)}.match-mid{color:var(--gold)}.match-low{color:#b5483a}
.diff .w-ok{color:var(--moss);font-weight:600}
.diff .w-miss{color:#b5483a;text-decoration:line-through;opacity:.6}

/* Plan list */
.week{background:var(--card);border:1px solid var(--line);border-radius:14px;padding:14px 16px;margin-bottom:10px;box-shadow:0 2px 0 var(--shadow)}
.week h4{font-family:'Fraunces',serif;font-size:17px;color:var(--rust-deep);display:flex;justify-content:space-between;align-items:center}
.week h4 span{font-size:12px;color:#8a7a64;font-weight:400;font-family:'Outfit'}
.week p{font-size:14px;color:#6a5c48;margin-top:6px;line-height:1.4}

.empty{text-align:center;padding:40px 20px;color:#8a7a64}
.empty .big{font-size:48px}
.note{font-size:12px;color:#8a7a64;text-align:center;margin-top:14px;line-height:1.5}
.progressbar{height:8px;background:var(--paper);border-radius:10px;overflow:hidden;margin-top:10px;border:1px solid var(--line)}
.progressbar i{display:block;height:100%;background:linear-gradient(90deg,var(--rust),var(--gold));width:0}
.toggle-vi{font-size:12px;color:var(--rust-deep);background:none;border:none;cursor:pointer;text-decoration:underline;margin-top:8px;font-family:'Outfit'}
</style>
</head>
<body>
<div class="wrap">
<header>
  <div class="logo">Work<span>English</span></div>
  <div class="tag">Học từ vựng công việc · Luyện nói mỗi tối 22:00</div>
</header>

<div class="stats">
  <div class="stat"><div class="n" id="s-learned">0</div><div class="l">Đã học</div></div>
  <div class="stat"><div class="n" id="s-due">0</div><div class="l">Cần ôn</div></div>
  <div class="stat"><div class="n" id="s-streak">0</div><div class="l">Ngày liên tiếp</div></div>
  <div class="stat"><div class="n" id="s-total">0</div><div class="l">Tổng từ</div></div>
</div>

<div class="tabs">
  <button class="tab active" data-view="learn">📖 Học từ</button>
  <button class="tab" data-view="speak">🎙️ Luyện nói</button>
  <button class="tab" data-view="plan">🗺️ Lộ trình</button>
  <button class="tab" data-view="settings">⚙️</button>
</div>

<p id="sync" style="text-align:center;font-size:12px;color:#8a7a64;min-height:16px;margin-bottom:10px"></p>

<div id="view-learn"></div>
<div id="view-speak" class="hidden"></div>
<div id="view-plan" class="hidden"></div>
<div id="view-settings" class="hidden"></div>

<p class="note">💡 Tiến độ được lưu trên trình duyệt này. Luyện nói cần Chrome/Edge/Safari và cho phép micro.</p>
</div>

